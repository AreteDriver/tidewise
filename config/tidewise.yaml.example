location:
  name: "Columbia River - Astoria"
  latitude: 46.1879
  longitude: -123.8313
  timezone: "America/Los_Angeles"

stations:
  tide: "9439040"           # NOAA station ID (Astoria, OR)
  water_temp: "9439040"
  usgs_gauge: null           # Optional USGS gauge for river data

preferences:
  units: imperial            # imperial | metric
  time_format: 12h           # 12h | 24h
  score_weights:
    solunar: 0.25
    tide: 0.25
    pressure: 0.20
    wind: 0.15
    cloud: 0.10
    precipitation: 0.05
    water_temp: 0.10         # optional — normalized with other weights

notifications:
  enabled: true
  method: ntfy               # ntfy | desktop | both | none
  ntfy_url: "https://ntfy.sh"
  ntfy_topic: "tidewise-fishing"
  alert_score: 8.0           # notify when score >= this
  cooldown_minutes: 60       # min time between alerts

history:
  enabled: true              # auto-log scores from today/score commands
  retention_days: 365        # purge records older than this

# Named location profiles — switch with: tidewise --profile newport today
profiles:
  astoria:
    location:
      name: "Columbia River - Astoria"
      latitude: 46.1879
      longitude: -123.8313
      timezone: "America/Los_Angeles"
    stations:
      tide: "9439040"
      water_temp: "9439040"
      usgs_gauge: "14246900"   # Columbia River at Beaver Army Terminal
  newport:
    location:
      name: "Yaquina Bay - Newport"
      latitude: 44.6253
      longitude: -124.0535
      timezone: "America/Los_Angeles"
    stations:
      tide: "9435380"
      water_temp: "9435380"
